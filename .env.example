# GEMINI_API_KEY: Required for Gemini AI API calls.
# OPENAI_API_KEY: Required for ChatGPT AI API calls.
# AI Studio automatically injects these at runtime from user secrets.
# Users configure these via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY
OPENAI_API_KEY=MY_OPENAI_API_KEY
